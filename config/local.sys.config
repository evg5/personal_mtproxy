%% -*- mode: erlang -*-
%% Local development config.
%% Use non-privileged ports (no root needed) and self-signed certs from priv/certs/.
%%
%% One-time setup:
%%   make dev-certs
%%   echo "127.0.0.1 demo.personal-mtp.test" | sudo tee -a /etc/hosts
%%
%% Then run:
%%   make dev
[
  {mtproto_proxy, [
    {ports, [
      #{name      => mtp_ipv4,
        listen_ip => "0.0.0.0",
        port      => 4433,
        secret    => <<"d0d6e111bada5511fcce9584deadbeef">>,
        tag       => <<"dcbe8f1493fa4cd9ab300891c0b5b326">>}
    ]},
    {allowed_protocols, [mtp_fake_tls]},
    {domain_fronting, "127.0.0.1:1443"},
    {policy, [
      {in_table, tls_domain, personal_domains},
      {max_connections, [tls_domain], 100}
    ]}
  ]},
  {personal_mtproxy, [
    {base_domain, "demo.personal-mtp.test"},
    {dets_file,   "personal_mtproxy_dev.dets"},
    {ssl_cert,    "priv/certs/cert.pem"},
    {ssl_key,     "priv/certs/key.pem"}
  ]},
  {kernel,
   [{logger_level, info},
    {logger,
     [{filters, log,
       [{progress, {fun logger_filters:progress/2, stop}}]},
      {handler, default, logger_std_h,
       #{level => info,
         formatter => {logger_formatter, #{single_line => true}},
         config => #{type => standard_io}}}
     ]}]}
].
